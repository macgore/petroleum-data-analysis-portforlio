{"cells":[{"cell_type":"code","source":["import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","from scipy.optimize import curve_fit\n","\n","print(\"Week 4 DCA environment ready\")"],"metadata":{"id":"7nyRxo6ty2nq","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1771855226038,"user_tz":-120,"elapsed":1005,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}},"outputId":"3af2e257-6fd1-4851-c57c-6bb6d063268a"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Week 4 DCA environment ready\n"]}]},{"cell_type":"code","source":["months = np.arange(0, 18)\n","\n","oil_rates = np.array([\n","    1600, 1500, 1420, 1350, 1280, 1220,\n","    1160, 1100, 1050, 1000, 950, 910,\n","    870, 840, 810, 780, 760, 740\n","])\n","\n","df = pd.DataFrame({\n","    \"Month\": months,\n","    \"Oil_Rate_bopd\": oil_rates\n","})\n","\n","df.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"kWf5aM2mz4nV","executionInfo":{"status":"ok","timestamp":1771855397789,"user_tz":-120,"elapsed":54,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}},"outputId":"c19280b7-0ee8-48e9-9128-ffb1c33565ff"},"execution_count":2,"outputs":[{"output_type":"execute_result","data":{"text/plain":["   Month  Oil_Rate_bopd\n","0      0           1600\n","1      1           1500\n","2      2           1420\n","3      3           1350\n","4      4           1280"],"text/html":["\n","  <div id=\"df-9d266611-566a-4574-9e52-0bfe2603d28b\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=