\")\n","plt.plot(t, q_exp_fit, label=\"Exponential Fit\")\n","plt.xlabel(\"Month\")\n","plt.ylabel(\"Oil Rate (bopd)\")\n","plt.title(\"Exponential Decline Fit\")\n","plt.legend()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"VghFbhcD0HXz","executionInfo":{"status":"ok","timestamp":1771855466766,"user_tz":-120,"elapsed":306,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}},"outputId":"2ffbbcf8-150e-4b1f-9078-3a5a696fe065"},"execution_count":5,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["def hyperbolic_decline(t, qi, D, b):\n","    return qi / ((1 + b * D * t) ** (1 / b))"],"metadata":{"id":"UqsArzsL0OWZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["params_hyp, _ = curve_fit(hyperbolic_decline, t, df[\"Oil_Rate_bopd\"], maxfev=5000)\n","\n","qi_hyp, D_hyp, b_hyp = params_hyp\n","qi_hyp, D_hyp, b_hyp"],"metadata":{"id":"4OGUsLPO0UIk"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def hyperbolic_decline(t, qi, D, b):\n","    return qi / ((1 + b * D * t) ** (1 / b))\n","\n","params_hyp, _ = curve_fit(hyperbolic_decline, t, df[\"Oil_Rate_bopd\"], maxfev=5000)\n","\n","qi_hyp, D_hyp, b_hyp = params_hyp\n","\n","q_hyp_fit = hyperbolic_decline(t, qi_hyp, D_hyp, b_hyp)\n","\n","plt.figure()\n","plt.plot(t, df[\"Oil_Rate_bopd\"], label=\"Actual\")\n","plt.plot(t, q_exp_fit, label=\"Exponential\")\n","plt.plot(t, q_hyp_fit, label=\"Hyperbolic\")\n","plt.xlabel(\"Month\")\n","plt.ylabel(\"Oil Rate (bopd)\")\n","plt.title(\"Decline Curve Comparison\")\n","plt.legend()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"86Jju8oc0gt4","executionInfo":{"status":"ok","timestamp":1771855593868,"user_tz":-120,"elapsed":289,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}},"outputId":"13a32c3b-db07-40f7-bb67-6d91cc40860a"},"execution_count":8,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["def harmonic_decline(t, qi, D):\n","    return qi / (1 + D * t)\n","\n","params_harm, _ = curve_fit(harmonic_decline, t, df[\"Oil_Rate_bopd\"])\n","\n","qi_harm, D_harm = params_harm\n","q_harm_fit = harmonic_decline(t, qi_harm, D_harm)"],"metadata":{"id":"QZe4vIpr0waS","executionInfo":{"status":"ok","timestamp":1771855655409,"user_tz":-120,"elapsed":11,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}}},"execution_count":11,"outputs":[]},{"cell_type":"code","source":["plt.figure()\n","plt.plot(t, df[\"Oil_Rate_bopd\"], label=\"Actual\")\n","plt.plot(t, q_exp_fit, label=\"Exponential\")\n","plt.plot(t, q_hyp_fit, label=\"Hyperbolic\")\n","plt.plot(t, q_harm_fit, label=\"Harmonic\")\n","plt.xlabel(\"Month\")\n","plt.ylabel(\"Oil Rate (bopd)\")\n","plt.title(\"All Decline Models Comparison\")\n","plt.legend()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"1B43uOuy017C","executionInfo":{"status":"ok","timestamp":1771855659222,"user_tz":-120,"elapsed":172,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}},"outputId":"62bffd63-2785-47cc-bf8e-ebae4b500cca"},"execution_count":12,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["forecast_months = np.arange(0, 60)\n","\n","q_forecast = hyperbolic_decline(forecast_months, qi_hyp, D_hyp, b_hyp)\n","\n","monthly_production = q_forecast * 30\n","EUR = np.sum(monthly_production)\n","\n","EUR"],"metadata":{"id":"fDrzbzFf1Cgm","executionInfo":{"status":"ok","timestamp":1771855695851,"user_tz":-120,"elapsed":36,"user":{"displayName":"macdonald goremusandu","userId":"13143539228510295636"}},"outputId":"381a8f27-316d-446d-c769-3c08687c70e4","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":13,"outputs":[{"output_type":"execute_result","data":{"text/plain":["np.float64(1105171.5218640957)"]},"metadata":{},"execution_count":13}]}],"metadata":{"colab":{"provenance":[{"file_id":"/v2/external/notebooks/intro.ipynb","timestamp":1771855156818}]},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}